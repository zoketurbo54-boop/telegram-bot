[Unit]
Description=MyPiskaGame Flask (Telegram mini app)
After=network.target

[Service]
Type=simple
User=piskagame
Group=piskagame
WorkingDirectory=/opt/mypiskagame
EnvironmentFile=/opt/mypiskagame/.env
ExecStart=/opt/mypiskagame/.venv/bin/python miniapp/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
